APP_NAME=Event Intelligence Agent
APP_VERSION=1.0.0
DEBUG=false

# Comma-separated list for CORS, e.g. https://your-frontend.onrender.com,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Render disk-backed SQLite (default) or external Postgres URL
DATABASE_URL=sqlite+aiosqlite:///./events.db

# LLM (optional, but recommended for richer ranking rationale)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=4096

# Embeddings (local model, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Optional event source APIs
TICKETMASTER_KEY=
EVENTBRITE_TOKEN=
LUMA_API_KEY=
SERPAPI_KEY=
ALLEVENTS_KEY=

# Scraper tuning
SCRAPE_DELAY_SECONDS=2.0
SCRAPE_TIMEOUT_SECONDS=15

# Scoring and ranking knobs
COSINE_WEIGHT=0.65
RULE_WEIGHT=0.35
GO_THRESHOLD=0.68
CONSIDER_THRESHOLD=0.42
TOP_K_FOR_LLM=20

# Optional scheduling interval (not auto-wired yet)
REFRESH_INTERVAL_HOURS=24

# Required for protected manual seeding endpoint: POST /api/seed-10times
SEED_ADMIN_TOKEN=

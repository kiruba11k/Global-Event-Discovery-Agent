APP_NAME=Event Intelligence Agent
APP_VERSION=1.0.0
DEBUG=false

# Comma-separated list for CORS, e.g. https://your-frontend.onrender.com,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Render disk-backed SQLite (default) or external Postgres URL
DATABASE_URL=sqlite+aiosqlite:///./events.db

# Number of Uvicorn worker processes (see Procfile). Default 1 — safe for
# a single Neon free-tier connection budget. Raise this for concurrent
# load, but set REDIS_URL first (below) or each worker enforces its own
# independent LLM cost budget/cache instead of sharing one.
WEB_CONCURRENCY=1

# Shared cache + daily-budget + rate-limit state across worker processes.
# Optional with WEB_CONCURRENCY=1; required once you run more than one
# worker/instance, or the OpenAI daily budget cap is no longer accurate
# (each worker would enforce its own copy of it).
REDIS_URL=

# LLM (optional, but recommended for richer ranking rationale)
# OpenAI bills per token — keep these on the mini/nano tier and tune
# OPENAI_DAILY_USD_BUDGET to whatever you're comfortable spending.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1024
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4.1-mini
OPENAI_TPM_LIMIT=40000
OPENAI_DAILY_USD_BUDGET=5.0

# Embeddings (local model, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Optional event source APIs
TICKETMASTER_KEY=
EVENTBRITE_TOKEN=
LUMA_API_KEY=
SERPAPI_KEY=
ALLEVENTS_KEY=

# Scraper tuning
SCRAPE_DELAY_SECONDS=2.0
SCRAPE_TIMEOUT_SECONDS=15

# Scoring and ranking knobs
COSINE_WEIGHT=0.65
RULE_WEIGHT=0.35
GO_THRESHOLD=0.68
CONSIDER_THRESHOLD=0.42
TOP_K_FOR_LLM=20

# Optional scheduling interval (not auto-wired yet)
REFRESH_INTERVAL_HOURS=24

# Required for protected manual seeding endpoint: POST /api/seed-10times
SEED_ADMIN_TOKEN=

# ── pgvector semantic matching (optional, Postgres/Neon only) ────
# OFF by default. On a free Render instance (512MB) do NOT set
# PGVECTOR_ALLOW_LOCAL_EMBEDDINGS=true — loading the local ONNX model
# (fastembed) is enough on its own to exceed the memory limit and get
# the whole process OOM-killed mid-request. If you want semantic
# search on a free instance, get a free Jina API key instead (network
# call, no local model) and leave local embeddings off.
PGVECTOR_ENABLED=false
JINA_API_KEY=
PGVECTOR_ALLOW_LOCAL_EMBEDDINGS=false
